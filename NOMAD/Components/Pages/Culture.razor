@page "/culture"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using NOMAD.Services
@using NOMAD.Models
@attribute [Authorize]
@rendermode InteractiveServer
@inject CultureService CultureAPI
@inject UserManager<ApplicationUser> UserManager

<PageTitle>NOMAD — Cultural Survival Guide</PageTitle>

<div class="culture-container animate-fadeIn">

    <div class="dashboard-header" style="margin-bottom: 2rem;">
        <h1 class="text-gradient">Cultural Survival Guide</h1>
        <p class="dashboard-subtitle">Classified intel on local customs, dress codes, greeting etiquettes, and operational threats.</p>
    </div>

    <div class="widget glass-panel mb-4" style="padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap;">
        <div>
            <h3 class="m-0 text-gradient" style="font-size: 1.25rem;"><i class="bi bi-globe-americas"></i> REGION INTEL COMPASS</h3>
            <span style="color: rgba(255,255,255,0.6); font-size: 0.85rem;">Select your target landing region to fetch custom social and safety guidelines.</span>
        </div>
        <div style="display: flex; gap: 12px; align-items: center;">
            <InputSelect class="nomad-input" style="width: 240px;" @bind-Value="selectedCountry" @bind-Value:after="OnCountryChanged">
                <option value="Turkey" style="background: var(--color-secondary); color: #fff;">Turkey Sector</option>
                <option value="Japan" style="background: var(--color-secondary); color: #fff;">Japan Sector</option>
                <option value="France" style="background: var(--color-secondary); color: #fff;">France Sector</option>
                <option value="Pakistan" style="background: var(--color-secondary); color: #fff;">Pakistan Sector</option>
            </InputSelect>
        </div>
    </div>

    <div class="widget-row two-col" style="grid-template-columns: 1.2fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">

        <div class="widget glass-panel" style="padding: 1.75rem;">
            <h3 class="widget-title" style="border-bottom: 1px solid rgba(212,175,55,0.2); padding-bottom: 0.75rem; margin-bottom: 1.25rem;">
                <i class="bi bi-shield-check" style="color: var(--color-primary);"></i> Regional Protocol & Etiquette
            </h3>

            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                <div>
                    <label class="nomad-label" style="font-size: 0.75rem; letter-spacing: 1px;">INITIAL GREETING ENCRYPTIONS</label>
                    <div style="font-size: 1.1rem; color: #fff; font-family: var(--font-display); background: rgba(255,255,255,0.03); padding: 0.75rem 1rem; border-left: 3px solid var(--color-primary); border-radius: 4px;">
                        "@guide.Greeting"
                    </div>
                </div>

                <div>
                    <label class="nomad-label" style="font-size: 0.75rem; letter-spacing: 1px;">COMMERCE & TIPPING PARADIGMS</label>
                    <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; line-height: 1.6;">@guide.TippingCulture</p>
                </div>

                <div>
                    <label class="nomad-label" style="font-size: 0.75rem; letter-spacing: 1px;">VISUAL TEXTURE & DRESS CODES</label>
                    <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; line-height: 1.6; margin-bottom: 0;">@guide.DressCode</p>
                </div>
            </div>
        </div>

        <div class="widget glass-panel" style="padding: 1.75rem;">
            <h3 class="widget-title" style="border-bottom: 1px solid rgba(212,175,55,0.2); padding-bottom: 0.75rem; margin-bottom: 1.25rem;">
                <i class="bi bi-bookmark-star" style="color: var(--color-primary);"></i> Mission Constraints (Do's & Don'ts)
            </h3>

            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.85rem;">
                @foreach (var item in guide.DosAndDonts)
                {
                    <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 0.95rem; color: rgba(255,255,255,0.85);">
                        <i class="bi bi-caret-right-fill" style="color: var(--color-primary); font-size: 0.9rem; margin-top: 2px;"></i>
                        <span>@item</span>
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="widget-row single-col">
        <div class="widget glass-panel" style="padding: 1.75rem; border: 1px solid rgba(197,160,40,0.25);">
            <h3 class="widget-title" style="color: var(--color-warning); border-bottom: 1px solid rgba(197,160,40,0.15); padding-bottom: 0.75rem; margin-bottom: 1.25rem;">
                <i class="bi bi-exclamation-octagon-fill"></i> KNOWN LOCAL SCAM VECTORS & THREATS
            </h3>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.25rem;">
                @foreach (var scam in guide.ScamAlerts)
                {
                    <div style="display: flex; align-items: flex-start; gap: 12px; background: rgba(197,160,40,0.04); padding: 1rem; border-radius: 6px; border: 1px solid rgba(197,160,40,0.08);">
                        <i class="bi bi-exclamation-triangle-fill" style="color: var(--color-warning); font-size: 1.1rem; margin-top: 1px;"></i>
                        <span style="font-size: 0.95rem; color: rgba(255,255,255,0.9); line-height: 1.5;">@scam</span>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@code {
    private CultureGuide guide = new();
    private string selectedCountry = "Turkey";

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private ApplicationUser? currentUser;

    protected override async Task OnInitializedAsync()
    {
    if (AuthState != null)
        {
            var authState = await AuthState;
            var userPrincipal = authState.User;
            if (userPrincipal.Identity?.IsAuthenticated == true)
            {
                currentUser = await UserManager.GetUserAsync(userPrincipal);
            }
        }

        selectedCountry = currentUser?.ActiveCountry ?? "Turkey";
        if (string.IsNullOrWhiteSpace(selectedCountry)) selectedCountry = "Turkey";

        LoadCultureGuide();
    }

    private void OnCountryChanged()
    {
        LoadCultureGuide();
    }

    private void LoadCultureGuide()
    {
        guide = CultureAPI.GetCultureGuide("", selectedCountry);
    }
}