@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using NOMAD.Services
@using NOMAD.Models
@attribute [Authorize]
@rendermode InteractiveServer
@inject DashboardService DashService
@inject UserManager<ApplicationUser> UserManager
@inject FinanceService FinanceAPI
@inject IJSRuntime JS

<PageTitle>NOMAD — Command Center</PageTitle>

<style>
    .nomad-dashboard-wrapper {
        padding: 2rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    .nomad-dashboard-wrapper .stats-row {
        display: grid !important;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)) !important;
        gap: 1.5rem !important;
        margin-bottom: 2rem !important;
    }

    .nomad-dashboard-wrapper .widget-row.two-col {
        display: grid !important;
        grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)) !important;
        gap: 1.75rem !important;
        margin-bottom: 1.75rem !important;
    }

    @@media (max-width: 768px) {
        .nomad-dashboard-wrapper .widget-row.two-col {
            grid-template-columns: 1fr !important;
        }
    }

    .nomad-dashboard-wrapper .stat-card.glass-panel {
        background: rgba(11, 35, 22, 0.45) !important;
        backdrop-filter: blur(12px) !important;
        -webkit-backdrop-filter: blur(12px) !important;
        border: 1px solid rgba(212, 175, 55, 0.15) !important;
        border-radius: 14px !important;
        padding: 1.5rem !important;
        display: flex !important;
        align-items: center !important;
        gap: 1.25rem !important;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.25) !important;
        transition: all 0.3s ease !important;
    }

    .nomad-dashboard-wrapper .stat-card.glass-panel:hover {
        border-color: rgba(212, 175, 55, 0.4) !important;
        transform: translateY(-2px);
    }

    .nomad-dashboard-wrapper .stat-icon {
        background: rgba(255, 255, 255, 0.02) !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        border-radius: 10px !important;
        width: 48px !important;
        height: 48px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        flex-shrink: 0 !important;
    }

    .nomad-dashboard-wrapper .stat-label {
        font-size: 0.75rem !important;
        font-family: monospace !important;
        color: rgba(255, 255, 255, 0.5) !important;
        text-transform: uppercase !important;
        letter-spacing: 1px !important;
        display: block !important;
        margin-bottom: 2px !important;
    }

    .nomad-dashboard-wrapper .stat-value {
        font-size: 1.45rem !important;
        font-weight: 700 !important;
        color: #ffffff !important;
        display: block !important;
    }

    .nomad-dashboard-wrapper .widget.glass-panel {
        background: rgba(11, 35, 22, 0.35) !important;
        backdrop-filter: blur(12px) !important;
        -webkit-backdrop-filter: blur(12px) !important;
        border: 1px solid rgba(255, 255, 255, 0.06) !important;
        border-radius: 16px !important;
        padding: 1.75rem !important;
    }

    .nomad-dashboard-wrapper .widget-title {
        font-size: 1.1rem !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
        padding-bottom: 0.85rem !important;
        margin-bottom: 1.25rem !important;
        display: flex !important;
        align-items: center !important;
        gap: 8px !important;
    }

    .nomad-chart-canvas-container {
        position: relative;
        width: 100%;
        height: 180px;
        margin-top: 0.5rem;
    }

    .nomad-budget-flex-container {
        display: flex !important;
        align-items: center !important;
        gap: 2rem !important;
        width: 100% !important;
    }

    .nomad-svg-ring-box {
        position: relative !important;
        width: 110px !important;
        height: 110px !important;
        flex-shrink: 0 !important;
    }

    .nomad-svg-ring-box svg {
        width: 100% !important;
        height: 100% !important;
        transform: rotate(-90deg);
    }

    .nomad-svg-ring-box .ring-bg {
        fill: none !important;
        stroke: rgba(255, 255, 255, 0.04) !important;
        stroke-width: 10 !important;
    }

    .nomad-svg-ring-box .ring-fill {
        fill: none !important;
        stroke: var(--color-accent, #e2a76f) !important;
        stroke-width: 10 !important;
        stroke-linecap: round !important;
        transition: stroke-dashoffset 0.4s ease !important;
    }

    .nomad-svg-ring-box .ring-text {
        position: absolute !important;
        top: 50% !important;
        left: 50% !important;
        transform: translate(-50%, -50%) !important;
        font-family: monospace !important;
        font-size: 1.15rem !important;
        font-weight: 700 !important;
        color: #ffffff !important;
    }

    .nomad-budget-details-list {
        display: flex !important;
        flex-direction: column !important;
        gap: 0.6rem !important;
        flex-grow: 1 !important;
    }

    .nomad-budget-details-line {
        display: flex !important;
        justify-content: space-between !important;
        font-size: 0.95rem !important;
        border-bottom: 1px solid rgba(255,255,255,0.03) !important;
        padding-bottom: 4px !important;
    }
</style>

<div class="nomad-dashboard-wrapper dashboard-container animate-fadeIn">

    <div class="dashboard-header" style="margin-bottom: 2rem;">
        <h1 class="text-gradient">Command Center</h1>
        <p class="dashboard-subtitle">All systems active — real-time travel intelligence online.</p>
    </div>

    @if (currentUser == null)
    {
        <div class="loading-state" style="padding: 5rem 0; text-align: center;">
            <span class="spinner"></span>
            <p style="margin-top: 1rem; color: var(--color-primary);">Booting NOMAD Travel Operating System...</p>
        </div>
    }
    else if (string.IsNullOrWhiteSpace(currentUser.ActiveDestination))
    {
        <div class="widget glass-panel animate-fadeIn text-center" style="margin-bottom: 2rem; padding: 4rem 2rem; background: linear-gradient(135deg, rgba(45, 74, 67, 0.2) 0%, rgba(27, 60, 51, 0.05) 100%); border: 1px solid var(--border-color);">
            <div class="mb-4">
                <i class="bi bi-compass-fill" style="font-size: 4rem; color: var(--color-accent); display: inline-block;"></i>
            </div>
            <h2 class="text-gradient" style="font-size: 2.2rem; font-weight: 700; margin-bottom: 0.5rem; letter-spacing: -0.5px;">Initialize Travel Operating System</h2>
            <p class="dashboard-subtitle" style="max-width: 600px; margin: 0 auto 2.5rem auto; font-size: 1.05rem; color: var(--color-text-muted);">
                Select your target coordinates to boot linguistic decryption, safe routing vectors, environmental meteorological satellites, and emergency SOS channels.
            </p>

            <EditForm Model="bootModel" OnValidSubmit="InitializeOS" FormName="OSBootForm" style="max-width: 500px; margin: 0 auto; text-align: left;">
                <div class="form-row-nomad mb-3">
                    <div class="form-group-nomad">
                        <label class="nomad-label">TARGET EXPLORER CITY</label>
                        <input type="text" class="nomad-input" @bind="bootModel.City" placeholder="e.g. Tokyo, Paris, Kyoto, Swiss Alps..." required style="border-color: var(--border-color);" />
                    </div>
                    <div class="form-group-nomad">
                        <label class="nomad-label">TARGET COUNTRY</label>
                        <input type="text" class="nomad-input" @bind="bootModel.Country" placeholder="e.g. Japan, France, Switzerland..." required style="border-color: var(--border-color);" />
                    </div>
                </div>
                <button type="submit" class="nomad-btn w-100" style="padding: 14px; font-weight: 600; letter-spacing: 0.5px; margin-top: 1rem;">
                    <i class="bi bi-cpu-fill"></i> INITIALIZE NOMAD ECOSYSTEM
                </button>
            </EditForm>
        </div>
    }
    else
    {
        <div class="widget glass-panel animate-fadeIn" style="margin-bottom: 2rem; padding: 2rem; background: linear-gradient(135deg, rgba(45, 74, 67, 0.25) 0%, rgba(226, 167, 111, 0.05) 100%); border: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.5rem;">
            <div>
                <span style="font-size: 0.8rem; font-weight: 600; color: var(--color-accent); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 0.5rem; display: block;">TRAVEL OPERATING SYSTEM ONLINE</span>
                <h2 style="font-size: 2.2rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 10px;">
                    <i class="bi bi-geo-alt-fill text-gradient"></i> Active Destination: @currentUser.ActiveDestination, @currentUser.ActiveCountry
                </h2>
                <p style="margin: 0.5rem 0 0 0; color: var(--color-text-muted); font-size: 0.95rem;">
                    Linguistic, safety, meteorological, and economic nodes fully synchronized to active coordinates.
                </p>
            </div>
            <button class="nomad-btn" @onclick="ReinitializeOS" style="padding: 10px 18px; border-color: var(--border-color); background: rgba(226, 167, 111, 0.1); color: var(--color-text);">
                <i class="bi bi-arrow-repeat"></i> REBOOT DESTINATION
            </button>
        </div>

        <div class="stats-row">
            @foreach (var stat in quickStats)
            {
                <div class="stat-card glass-panel animate-fadeIn">
                    <div class="stat-icon" style="color: @(stat.Color == "#e2a76f" ? "var(--color-accent)" : stat.Color);">
                        <i class="bi @stat.Icon" style="font-size: 1.35rem;"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">@stat.Label</span>
                        <span class="stat-value">@stat.Value</span>
                    </div>
                </div>
            }
        </div>

        <div class="widget-row two-col">
            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-wallet2" style="color: var(--color-accent);"></i> Budget Overview</h3>
                <div class="nomad-budget-flex-container">
                    <div class="nomad-svg-ring-box">
                        <svg viewBox="0 0 120 120">
                            <circle cx="60" cy="60" r="52" class="ring-bg" />
                            <circle cx="60" cy="60" r="52" class="ring-fill"
                                    style="stroke-dasharray: 327; stroke-dashoffset: @(327 - (327 * budget.PercentUsed / 100))" />
                        </svg>
                        <span class="ring-text">@(budget.PercentUsed)%</span>
                    </div>
                    <div class="nomad-budget-details-list">
                        <div class="nomad-budget-details-line">
                            <span style="color: rgba(255,255,255,0.5);">Total Budget</span>
                            <span style="font-weight: 600; color: #ffffff;">@(budget.TotalBudget.ToString("N0")) @budget.Currency</span>
                        </div>
                        <div class="nomad-budget-details-line">
                            <span style="color: rgba(255,255,255,0.5);">Spent</span>
                            <span style="font-weight: 600; color: #f87171;">@(budget.Spent.ToString("N2")) @budget.Currency</span>
                        </div>
                        <div class="nomad-budget-details-line">
                            <span style="color: rgba(255,255,255,0.5);">Remaining</span>
                            <span style="font-weight: 600; color: #4ade80;">@(budget.Remaining.ToString("N2")) @budget.Currency</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-activity" style="color: #4ade80;"></i> Financial Runway Analytics (@budget.Currency)</h3>
                <div class="nomad-chart-canvas-container">
                    <canvas id="nomadBudgetHistoryChart"></canvas>
                </div>
            </div>
        </div>

        <div class="widget-row two-col">
            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-airplane-fill"></i> Active Trip</h3>
                <div class="trip-info">
                    <div class="trip-destination">
                        <span class="trip-city">@trip.Destination</span>
                        <span class="trip-country">@trip.Country</span>
                    </div>
                    <div class="trip-meta">
                        <span class="trip-status-badge">@trip.Status</span>
                        <span class="trip-days">@trip.DaysRemaining days left</span>
                    </div>
                    <div class="progress-bar-wrapper">
                        <div class="progress-bar-track">
                            <div class="progress-bar-fill" style="width: @(trip.ProgressPercent)%"></div>
                        </div>
                        <span class="progress-label">@(trip.ProgressPercent)% Complete</span>
                    </div>
                </div>
            </div>

            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-cloud-sun-fill"></i> Weather Intel</h3>
                <div class="weather-display">
                    <div class="weather-main">
                        <i class="bi @weather.Icon weather-big-icon" style="color: var(--color-accent);"></i>
                        <div>
                            <span class="weather-temp">@(weather.Temperature)°C</span>
                            <span class="weather-condition">@weather.Condition</span>
                        </div>
                    </div>
                    <div class="weather-details">
                        <div class="weather-detail">
                            <i class="bi bi-droplet-fill"></i>
                            <span>@(weather.Humidity)% Humidity</span>
                        </div>
                        <div class="weather-detail">
                            <i class="bi bi-wind"></i>
                            <span>@(weather.WindSpeed) km/h Wind</span>
                        </div>
                        <div class="weather-detail">
                            <i class="bi bi-geo-fill"></i>
                            <span>@weather.City</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <div class="widget-row two-col">
            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-currency-exchange"></i> Exchange Rates</h3>
                <div class="rates-list">
                    @foreach (var rate in exchangeRates)
                    {
                        <div class="rate-item">
                            <span class="rate-pair">@rate.From → @rate.To</span>
                            <span class="rate-value">@rate.Rate</span>
                            <span class="rate-change @(rate.Change >= 0 ? "up" : "down")">
                                <i class="bi @(rate.Change >= 0 ? "bi-arrow-up-short" : "bi-arrow-down-short")"></i>
                                @Math.Abs(rate.Change)%
                            </span>
                        </div>
                    }
                </div>
            </div>

            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-translate"></i> Translation Memory</h3>
                <div class="translations-list">
                    @foreach (var translation in recentTranslations)
                    {
                        <div class="translation-item">
                            <div class="translation-original">@translation.Original</div>
                            <div class="translation-result">
                                <i class="bi bi-arrow-return-right"></i> @translation.Translated
                            </div>
                        </div>
                    }
                </div>
                <a href="/translate" class="nomad-btn text-center d-block w-100" style="margin-top: 1rem; padding: 10px; text-decoration: none;"><i class="bi bi-translate"></i> OPEN TRANSLATOR</a>
            </div>
        </div>

      
        <div class="widget-row two-col">
            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-geo-alt-fill"></i> Active Route</h3>
                <div class="route-display">
                    <div class="route-line">
                        <span class="route-point">@activeRoute.Origin</span>
                        <i class="bi bi-arrow-down" style="color: var(--color-text-muted); margin: 8px 0;"></i>
                        <span class="route-point">@activeRoute.Destination</span>
                    </div>
                    <div class="route-meta">
                        <span class="route-badge"><i class="bi bi-train-front"></i> @activeRoute.TransportMode</span>
                        <span class="route-eta">ETA: @activeRoute.ETA</span>
                    </div>
                </div>
            </div>

            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-pin-map-fill"></i> Nearby Locations</h3>
                <div class="places-list">
                    @foreach (var place in nearbyPlaces)
                    {
                        <div class="place-item">
                            <i class="bi @place.Icon place-icon"></i>
                            <div class="place-info">
                                <span class="place-name">@place.Name</span>
                                <span class="place-type">@place.Type</span>
                            </div>
                            <span class="place-distance">@place.Distance</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="widget-row two-col">
            <div class="widget glass-panel" style="border-color: var(--color-danger);">
                <h3 class="widget-title" style="color: var(--color-accent);"><i class="bi bi-telephone-fill"></i> Local SOS Emergency Numbers</h3>
                <div class="emergency-grid">
                    @foreach (var sos in emergencyShortcuts)
                    {
                        <div class="sos-card" style="background: rgba(216, 90, 90, 0.05); border-color: rgba(216, 90, 90, 0.15);">
                            <i class="bi @sos.Icon sos-icon" style="color: var(--color-accent);"></i>
                            <span class="sos-title">@sos.Title</span>
                            <span class="sos-number" style="color: var(--color-accent);">@sos.Number</span>
                        </div>
                    }
                </div>
            </div>

            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-stars"></i> AI Survival Recommendations</h3>
                <div class="recommendations-list">
                    @foreach (var rec in recommendations)
                    {
                        <div class="rec-item">
                            <i class="bi bi-chevron-right rec-arrow" style="color: var(--color-accent);"></i>
                            <span>@rec</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="widget-row">
            <div class="widget glass-panel">
                <h3 class="widget-title"><i class="bi bi-exclamation-triangle-fill"></i> Danger Alerts</h3>
                <div class="alerts-list">
                    @if (!dangerAlerts.Any())
                    {
                        <div class="rec-item text-muted text-center py-3">
                            <i class="bi bi-shield-check text-success" style="font-size: 1.5rem; display: block; margin-bottom: 0.5rem;"></i>
                            <span>No active threats detected in this sector. Safe passage confirmed.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var alert in dangerAlerts)
                        {
                            <div class="danger-item @(alert.Level.ToLower())" style="margin-bottom: 0.75rem;">
                                <i class="bi @alert.Icon"></i>
                                <div class="danger-info">
                                    <span class="danger-title">@alert.Title</span>
                                    <span class="danger-region">@alert.Region</span>
                                </div>
                                <span class="danger-badge @(alert.Level.ToLower())">@alert.Level</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }

</div>

@code {
    private ApplicationUser? currentUser;
    private BootDto bootModel = new();

    private List<QuickStat> quickStats = new();
    private TripStatus trip = new();
    private WeatherInfo weather = new();
    private BudgetSummary budget = new();
    private List<ExchangeRate> exchangeRates = new();
    private List<DangerAlert> dangerAlerts = new();
    private List<NearbyPlace> nearbyPlaces = new();
    private List<string> recommendations = new();
    private List<EmergencyShortcut> emergencyShortcuts = new();
    private List<TranslationTool> recentTranslations = new();
    private ActiveRoute activeRoute = new();

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var authState = await AuthState;
            var userPrincipal = authState.User;
            if (userPrincipal.Identity?.IsAuthenticated == true)
            {
                currentUser = await UserManager.GetUserAsync(userPrincipal);
                if (currentUser != null && !string.IsNullOrWhiteSpace(currentUser.ActiveDestination))
                {
                    LoadDashboardData(currentUser.ActiveDestination, currentUser.ActiveCountry ?? "");
                }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (currentUser != null && !string.IsNullOrWhiteSpace(currentUser.ActiveDestination) && budget != null)
        {
            try
            {
                double total = budget.TotalBudget > 0 ? (double)budget.TotalBudget : 3000;
                double spent = (double)budget.Spent;
                double halfSpent = spent * 0.6;
                double earlySpent = spent * 0.25;

                await JS.InvokeVoidAsync("eval", $@"
                    (function() {{
                        var ctx = document.getElementById('nomadBudgetHistoryChart');
                        if (!ctx) return;
                        
                        if (window.nomadBudgetChartObj) {{
                            window.nomadBudgetChartObj.destroy();
                        }}

                        window.nomadBudgetChartObj = new Chart(ctx, {{
                            type: 'line',
                            data: {{
                                labels: ['Day 1', 'Day 3', 'Day 5', 'Current'],
                                datasets: [{{
                                    label: 'Available Runway ({budget.Currency})',
                                    data: [{total}, {total - earlySpent}, {total - halfSpent}, {total - spent}],
                                    borderColor: '#e2a76f',
                                    backgroundColor: 'rgba(226, 167, 111, 0.05)',
                                    borderWidth: 2,
                                    pointBackgroundColor: '#e2a76f',
                                    pointRadius: 3,
                                    tension: 0.2,
                                    fill: true
                                }}]
                            }},
                            options: {{
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {{
                                    legend: {{ display: false }}
                                }},
                                scales: {{
                                    x: {{ 
                                        grid: {{ color: 'rgba(255,255,255,0.03)' }}, 
                                        ticks: {{ color: 'rgba(255,255,255,0.4)', font: {{ size: 10 }} }} 
                                    }},
                                    y: {{ 
                                        grid: {{ color: 'rgba(255,255,255,0.03)' }}, 
                                        ticks: {{ color: 'rgba(255,255,255,0.4)', font: {{ size: 10 }} }} 
                                    }}
                                }}
                            }}
                        }});
                    }})()
                ");
            }
            catch { }
        }
    }

    private void LoadDashboardData(string city, string country)
    {
        quickStats = DashService.GetQuickStats(city, country);
        trip = DashService.GetActiveTripStatus(city, country);
        weather = DashService.GetCurrentWeather(city, country);
        budget = DashService.GetBudgetSummary(city, country);
        exchangeRates = DashService.GetExchangeRates(city, country);
        dangerAlerts = DashService.GetDangerAlerts(city, country);
        nearbyPlaces = DashService.GetNearbyPlaces(city, country);
        recommendations = DashService.GetAIRecommendations(city, country);
        emergencyShortcuts = DashService.GetEmergencyShortcuts(city, country);
        recentTranslations = DashService.GetRecentTranslations(city, country);
        activeRoute = DashService.GetActiveRoute(city, country);
    }

    private async Task InitializeOS()
    {
        if (currentUser != null && !string.IsNullOrWhiteSpace(bootModel.City))
        {
            currentUser.ActiveDestination = bootModel.City.Trim();
            currentUser.ActiveCountry = bootModel.Country.Trim();

            FinanceAPI.SeedForDestination(currentUser.ActiveDestination, currentUser.ActiveCountry);

            await UserManager.UpdateAsync(currentUser);
            LoadDashboardData(currentUser.ActiveDestination, currentUser.ActiveCountry);
            StateHasChanged();
        }
    }

    private async Task ReinitializeOS()
    {
        if (currentUser != null)
        {
            currentUser.ActiveDestination = null;
            currentUser.ActiveCountry = null;
            await UserManager.UpdateAsync(currentUser);
            bootModel = new();
            StateHasChanged();
        }
    }

    public class BootDto
    {
        public string City { get; set; } = "";
        public string Country { get; set; } = "";
    }
}