@page "/forgot-password"
@layout AuthLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using NOMAD.DTOs
@using NOMAD.Models
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>NOMAD — Reset Passkey</PageTitle>

<div class="auth-hero">
    <div class="auth-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=80'); filter: sepia(0.3) brightness(0.4) contrast(1.1);"></div>
    <div class="auth-hero-content">
        <h1 style="font-family: var(--font-display); letter-spacing: 2px;">Restore Access.</h1>
        <p style="font-size: 1.15rem; opacity: 0.85; line-height: 1.7; font-family: var(--font-body); max-width: 520px;">
            Reset your encryption passkey to restore access to your offline intelligence vaults, cached terminal states, and local sector navigation matrices.
        </p>
    </div>
</div>

<div class="auth-form-side" style="display: flex; align-items: center; justify-content: center; padding: 2rem;">
    <div class="auth-card glass-panel animate-fadeIn" style="max-width: 480px; width: 100%; padding: 2.5rem; border: 1px solid rgba(212,175,55,0.15); box-shadow: 0 15px 35px rgba(0,0,0,0.4);">

        <div class="auth-logo" style="text-align: center; margin-bottom: 2.25rem;">
            <h1 class="text-gradient" style="font-family: var(--font-display); font-weight: 900; letter-spacing: 3px; margin-bottom: 0.25rem; font-size: 2.25rem;">NOMAD</h1>
            <p style="color: rgba(255,255,255,0.4); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1.5px; margin: 0;">Encryption Passkey Override</p>
        </div>

        <EditForm Model="resetModel" OnValidSubmit="HandleResetPassword" FormName="ForgotPasswordForm">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="animate-fadeIn" style="background: rgba(64,145,108,0.08); border: 1px solid rgba(64,145,108,0.25); color: #fff; padding: 1rem; border-radius: 6px; font-size: 0.9rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;">
                    <i class="bi bi-check-circle-fill" style="color: var(--color-success); font-size: 1.1rem;"></i>
                    <span>@successMessage</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="animate-fadeIn" style="background: rgba(211,47,47,0.08); border: 1px solid rgba(211,47,47,0.25); color: #fff; padding: 1rem; border-radius: 6px; font-size: 0.9rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;">
                    <i class="bi bi-exclamation-octagon-fill" style="color: var(--color-danger); font-size: 1.1rem;"></i>
                    <span>@errorMessage</span>
                </div>
            }

            <div style="margin-bottom: 1.25rem;">
                <label class="nomad-label" style="font-size: 0.75rem; letter-spacing: 1px;">EXPLORER IDENTIFICATION EMAIL</label>
                <div style="position: relative;">
                    <i class="bi bi-envelope" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); font-size: 1rem;"></i>
                    <InputText class="nomad-input" placeholder="identity@nomad.sector" style="padding-left: 2.75rem; width: 100%;" @bind-Value="resetModel.Email" autocomplete="username" />
                </div>
                <ValidationMessage For="() => resetModel.Email" style="color: var(--color-danger); font-size: 0.8rem; margin-top: 0.4rem; display: block;" />
            </div>

            <div style="margin-bottom: 1.25rem;">
                <label class="nomad-label" style="font-size: 0.75rem; letter-spacing: 1px;">NEW ENCRYPTION PASSKEY</label>
                <div style="position: relative;">
                    <i class="bi bi-shield-lock" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); font-size: 1rem;"></i>
                    <InputText type="@(showPassword ? "text" : "password")" class="nomad-input" placeholder="••••••••••••" style="padding-left: 2.75rem; padding-right: 2.75rem; width: 100%;" @bind-Value="resetModel.NewPassword" autocomplete="new-password" />
                    <button type="button" @onclick="TogglePasswordVisibility" style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 0;">
                        <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                </div>
                <ValidationMessage For="() => resetModel.NewPassword" style="color: var(--color-danger); font-size: 0.8rem; margin-top: 0.4rem; display: block;" />
            </div>

            <div style="margin-bottom: 2rem;">
                <label class="nomad-label" style="font-size: 0.75rem; letter-spacing: 1px;">CONFIRM NEW PASSKEY</label>
                <div style="position: relative;">
                    <i class="bi bi-shield-check" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); font-size: 1rem;"></i>
                    <InputText type="@(showConfirmPassword ? "text" : "password")" class="nomad-input" placeholder="••••••••••••" style="padding-left: 2.75rem; padding-right: 2.75rem; width: 100%;" @bind-Value="resetModel.ConfirmNewPassword" autocomplete="new-password" />
                    <button type="button" @onclick="ToggleConfirmPasswordVisibility" style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; padding: 0;">
                        <i class="bi @(showConfirmPassword ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                </div>
                <ValidationMessage For="() => resetModel.ConfirmNewPassword" style="color: var(--color-danger); font-size: 0.8rem; margin-top: 0.4rem; display: block;" />
            </div>

            <button type="submit" class="nomad-btn" style="width: 100%; padding: 0.85rem; font-family: var(--font-display); font-weight: 700; letter-spacing: 1px;" disabled="@isLoading">
                @if (isLoading)
                {
                    <span style="display: flex; align-items: center; justify-content: center; gap: 8px;">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="width: 14px; height: 14px;"></span>
                        OVERRIDING CORE ACCESS...
                    </span>
                }
                else
                {
                    <span><i class="bi bi-arrow-repeat"></i> OVERRIDE & RESET PASSKEY</span>
                }
            </button>
        </EditForm>

        <div style="margin-top: 2rem; text-align: center; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.5rem;">
            <a href="/login" style="color: var(--color-primary); font-size: 0.85rem; text-decoration: none; font-family: var(--font-display); letter-spacing: 0.5px; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--color-primary)'">
                <i class="bi bi-arrow-left"></i> RETURN TO MAIN CORE LOGIN
            </a>
        </div>

    </div>
</div>

@code {
    private ForgotPasswordDto resetModel = new();
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;
    private bool showPassword = false;
    private bool showConfirmPassword = false;

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        showConfirmPassword = !showConfirmPassword;
    }

    private async Task HandleResetPassword()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var user = await UserManager.FindByEmailAsync(resetModel.Email);
            if (user == null)
            {
                errorMessage = "No explorer account found with that email address.";
                isLoading = false;
                return;
            }

            var token = await UserManager.GeneratePasswordResetTokenAsync(user);
            var result = await UserManager.ResetPasswordAsync(user, token, resetModel.NewPassword);

            if (result.Succeeded)
            {
                successMessage = "Password successfully reset! Redirecting to login...";
                StateHasChanged();
                await Task.Delay(2000);
                Navigation.NavigateTo("/login");
            }
            else
            {
                errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"System error resetting password: {ex.Message}";
        }

        isLoading = false;
    }
}