@page "/profile"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using NOMAD.DTOs
@using NOMAD.Models
@attribute [Authorize]
@rendermode InteractiveServer
@inject UserManager<ApplicationUser> UserManager

<PageTitle>NOMAD — Explorer Profile</PageTitle>

<div class="profile-page-container animate-fadeIn" style="max-width: 1400px; margin: 0 auto; padding: 1rem;">

    <div class="dashboard-header" style="margin-bottom: 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1.5rem;">
        <h1 class="text-gradient" style="background: linear-gradient(135deg, #FFF 30%, var(--color-primary, #D4AF37) 100%); font-family: var(--font-display), 'Cinzel', serif; font-weight: 900; letter-spacing: 1.5px; margin-bottom: 0.5rem; text-transform: uppercase; font-size: 2.2rem;">
            Explorer Profile
        </h1>
        <p class="dashboard-subtitle" style="font-family: var(--font-body), 'Inter', sans-serif; color: rgba(255,255,255,0.6); margin: 0; font-size: 0.95rem; letter-spacing: 0.3px;">
            Manage credentials, look up secure identity tokens, and log global territorial crossings.
        </p>
    </div>

    @if (successMessage != null)
    {
        <div class="alert alert-success animate-fadeIn" style="background: rgba(64,145,108,0.15); border: 1px solid var(--color-success, #40916c); color: #fff; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; font-family: var(--font-body); display: flex; align-items: center; gap: 0.5rem;">
            <i class="bi bi-check-circle-fill" style="color: var(--color-success, #40916c);;"></i> @successMessage
        </div>
    }
    @if (errorMessage != null)
    {
        <div class="alert alert-danger animate-fadeIn" style="background: rgba(211,47,47,0.15); border: 1px solid var(--color-danger, #D32F2F); color: #fff; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; font-family: var(--font-body); display: flex; align-items: center; gap: 0.5rem;">
            <i class="bi bi-exclamation-triangle-fill" style="color: var(--color-danger, #D32F2F);;"></i> @errorMessage
        </div>
    }

    @if (profileModel != null)
    {
        <div class="profile-main-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 380px), 1fr)); gap: 2rem; align-items: start;">

            <div class="widget glass-panel" style="background: rgba(11, 35, 22, 0.3); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 2.5rem; position: relative; box-shadow: 0 20px 40px rgba(0,0,0,0.25); min-height: 520px; min-width: 0;">

                <button @onclick="ToggleEditMode" type="button" title="Modify Registry Information" style="position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); width: 42px; height: 42px; border-radius: 50%; color: var(--color-primary, #D4AF37); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s ease; font-size: 1.1rem; z-index: 10;" onmouseover="this.style.background='rgba(212,175,55,0.15)'; this.style.borderColor='var(--color-primary)';" onmouseout="this.style.background='rgba(255,255,255,0.03)'; this.style.borderColor='rgba(255,255,255,0.1)';">
                    <i class="bi @(isEditing ? "bi-x-lg" : "bi-pencil-fill")"></i>
                </button>

                @if (!isEditing)
                {
                    <div class="profile-view-hud text-center animate-fadeIn" style="display: flex; flex-direction: column; align-items: center; text-align: center;">

                        <div class="avatar-frame" style="position: relative; width: 130px; height: 130px; border-radius: 50%; padding: 4px; border: 2px solid var(--color-primary, #D4AF37); margin-bottom: 1.25rem; box-shadow: 0 0 20px rgba(212,175,55,0.2); background: rgba(0,0,0,0.4);">
                            @if (!string.IsNullOrWhiteSpace(profileModel.ProfilePictureUrl))
                            {
                                <img src="@profileModel.ProfilePictureUrl" alt="Explorer Avatar" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                            }
                            else
                            {
                                <div style="width:100%; height:100%; border-radius:50%; display:flex; align-items:center; justify-content:center; background:rgba(255,255,255,0.05); color:var(--color-primary); font-size:2.5rem;">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                            }
                        </div>

                        <h2 style="font-family: var(--font-display), 'Cinzel', serif; font-weight: 700; color: #fff; margin: 0 0 0.25rem 0; font-size: 1.6rem; letter-spacing: 0.5px;">@profileModel.FullName</h2>
                        <p style="font-family: monospace; color: var(--color-primary, #D4AF37); font-size: 0.9rem; margin: 0 0 1.5rem 0; letter-spacing: 0.5px;">@userEmail</p>

                        <div style="background: rgba(0,0,0,0.15); border-radius: 8px; border: 1px solid rgba(255,255,255,0.03); padding: 1.1rem; width: 100%; max-width: 450px; margin-bottom: 2rem; box-shadow: inset 0 2px 8px rgba(0,0,0,0.2);">
                            <span style="font-family: var(--font-display), 'Cinzel', serif; font-size: 0.65rem; color: rgba(255,255,255,0.4); letter-spacing: 1px; display: block; margin-bottom: 0.4rem; text-transform: uppercase;">Bio & Narrative Logs</span>
                            <p style="font-family: var(--font-body), 'Inter', sans-serif; font-size: 0.9rem; color: rgba(255,255,255,0.75); line-height: 1.6; margin: 0; font-style: italic;">
                                @(string.IsNullOrWhiteSpace(profileModel.Bio) ? "Enter something that describes you" : profileModel.Bio)
                            </p>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; width: 100%; text-align: left;">
                            <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 0.85rem; border-radius: 6px; min-width: 0;">
                                <small style="display:block; font-size:0.7rem; color:rgba(255,255,255,0.4); font-family:var(--font-display);">NATIONALITY</small>
                                <span style="color:#fff; font-size:0.95rem; font-weight:500; font-family:var(--font-body); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><i class="bi bi-flag" style="color:var(--color-primary); margin-right:4px;"></i> @(profileModel.Nationality ?? "Unspecified")</span>
                            </div>
                            <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 0.85rem; border-radius: 6px; min-width: 0;">
                                <small style="display:block; font-size:0.7rem; color:rgba(255,255,255,0.4); font-family:var(--font-display);">TELEMETRY LINK</small>
                                <span style="color:#fff; font-size:0.95rem; font-weight:500; font-family:var(--font-body); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><i class="bi bi-telephone" style="color:var(--color-primary); margin-right:4px;"></i> @(profileModel.PhoneNumber ?? "Unassigned")</span>
                            </div>
                            <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 0.85rem; border-radius: 6px; min-width: 0;">
                                <small style="display:block; font-size:0.7rem; color:rgba(255,255,255,0.4); font-family:var(--font-display);">PRIMARY LANGUAGE</small>
                                <span style="color:#fff; font-size:0.95rem; font-weight:500; font-family:var(--font-body); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><i class="bi bi-translate" style="color:var(--color-primary); margin-right:4px;"></i> @profileModel.PreferredLanguage</span>
                            </div>
                            <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 0.85rem; border-radius: 6px; min-width: 0;">
                                <small style="display:block; font-size:0.7rem; color:rgba(255,255,255,0.4); font-family:var(--font-display);">CURRENCY MATRIX</small>
                                <span style="color:#fff; font-size:0.95rem; font-weight:500; font-family:var(--font-body); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><i class="bi bi-cash-coin" style="color:var(--color-primary); margin-right:4px;"></i> @profileModel.PreferredCurrency</span>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <EditForm Model="profileModel" OnValidSubmit="HandleUpdate" class="animate-fadeIn">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger" style="font-size:0.85rem; margin-bottom:1rem; font-family:var(--font-body);" />

                        <h3 style="font-family: var(--font-display), 'Cinzel', serif; font-size: 1.05rem; color: var(--color-primary, #D4AF37); margin: 0 0 1.5rem 0; border-bottom: 1px solid rgba(212,175,55,0.15); padding-bottom: 0.5rem; letter-spacing: 0.5px;">EDIT PROFILE METADATA</h3>

                        <div style="display:flex; flex-direction:column; gap:1.1rem; max-height: 480px; overflow-y:auto; padding-right:4px;" class="custom-scrollbar">

                            <div>
                                <label style="display:block; font-family:var(--font-display); font-size:0.72rem; color:rgba(255,255,255,0.6); margin-bottom:0.35rem; letter-spacing:0.5px;">PROFILE PICTURE IMAGE URL</label>
                                <InputText @bind-Value="profileModel.ProfilePictureUrl" class="nomad-input" style="width:100%; padding:0.6rem; background:rgba(0,0,0,0.25); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:4px; font-family:monospace; font-size:0.85rem;" placeholder="https://image-link-location.jpg" />
                            </div>

                            <div>
                                <label style="display:block; font-family:var(--font-display); font-size:0.72rem; color:rgba(255,255,255,0.6); margin-bottom:0.35rem; letter-spacing:0.5px;">EXPLORER FULL NAME</label>
                                <InputText @bind-Value="profileModel.FullName" class="nomad-input" style="width:100%; padding:0.6rem; background:rgba(0,0,0,0.25); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:4px; font-family:var(--font-body);" />
                            </div>

                            <div>
                                <label style="display:block; font-family:var(--font-display); font-size:0.72rem; color:rgba(255,255,255,0.6); margin-bottom:0.35rem; letter-spacing:0.5px;">PERSONAL BIO BRIEF</label>
                                <InputTextArea @bind-Value="profileModel.Bio" rows="3" class="nomad-input" style="width:100%; padding:0.6rem; background:rgba(0,0,0,0.25); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:4px; font-family:var(--font-body); resize:none; font-size:0.88rem;" placeholder="Write a short summary about your background..." />
                            </div>

                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                                <div>
                                    <label style="display:block; font-family:var(--font-display); font-size:0.72rem; color:rgba(255,255,255,0.6); margin-bottom:0.35rem;">NATIONALITY</label>
                                    <InputText @bind-Value="profileModel.Nationality" class="nomad-input" style="width:100%; padding:0.6rem; background:rgba(0,0,0,0.25); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:4px;" />
                                </div>
                                <div>
                                    <label style="display:block; font-family:var(--font-display); font-size:0.72rem; color:rgba(255,255,255,0.6); margin-bottom:0.35rem;">PHONE TELEMETRY</label>
                                    <InputText @bind-Value="profileModel.PhoneNumber" class="nomad-input" style="width:100%; padding:0.6rem; background:rgba(0,0,0,0.25); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:4px;" />
                                </div>
                            </div>

                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                                <div>
                                    <label style="display:block; font-family:var(--font-display); font-size:0.72rem; color:rgba(255,255,255,0.6); margin-bottom:0.35rem;">PREFERRED TONGUE</label>
                                    <InputText @bind-Value="profileModel.PreferredLanguage" class="nomad-input" style="width:100%; padding:0.6rem; background:rgba(0,0,0,0.25); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:4px;" />
                                </div>
                                <div>
                                    <label style="display:block; font-family:var(--font-display); font-size:0.72rem; color:rgba(255,255,255,0.6); margin-bottom:0.35rem;">CURRENCY SYMBOL</label>
                                    <InputText @bind-Value="profileModel.PreferredCurrency" class="nomad-input" style="width:100%; padding:0.6rem; background:rgba(0,0,0,0.25); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:4px;" />
                                </div>
                            </div>

                            <div style="margin-top:0.5rem; display:flex; gap:1rem;">
                                <button type="submit" class="nomad-btn" style="background: linear-gradient(135deg, var(--color-primary, #D4AF37) 0%, #AA8414 100%); border:none; color:#05120A; font-weight:700; flex:1; padding:0.75rem; border-radius:4px; font-family:var(--font-display); cursor:pointer; font-size:0.85rem; letter-spacing:0.5px;">
                                    SAVE REVISIONS
                                </button>
                                <button type="button" @onclick="ToggleEditMode" class="nomad-btn" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.75rem; border-radius:4px; font-family:var(--font-display); cursor:pointer; font-size:0.85rem;" onmouseover="this.style.background='rgba(255,255,255,0.1)';" onmouseout="this.style.background='rgba(255,255,255,0.05)';">
                                    CANCEL
                                </button>
                            </div>

                        </div>
                    </EditForm>
                }
            </div>

            <div class="widget glass-panel" style="background: rgba(11, 35, 22, 0.3); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 2rem; min-height: 520px; box-shadow: 0 20px 40px rgba(0,0,0,0.25); display: flex; flex-direction: column; justify-content: space-between; min-width: 0;">
                <div>
                    <h3 class="widget-title" style="border-bottom: 1px solid rgba(212,175,55,0.15); padding-bottom: 1rem; margin-bottom: 1.5rem; font-family: var(--font-display), 'Cinzel', serif; font-weight: 700; letter-spacing: 1px; font-size: 1.1rem; display: flex; align-items: center; gap: 0.5rem; color: #fff;">
                        <i class="bi bi-globe-americas" style="color: var(--color-primary, #D4AF37);"></i> VISITED COUNTRIES LOGS
                    </h3>

                    <div style="background:rgba(0,0,0,0.2); border:1px solid rgba(255,255,255,0.04); border-radius:8px; padding:1rem; margin-bottom:1.5rem;">
                        <span style="font-family:var(--font-display); font-size:0.68rem; color:var(--color-primary, #D4AF37); display:block; margin-bottom:0.6rem; font-weight:700; letter-spacing:0.5px;">RECORD A VISITED REGION ENTRY</span>
                        <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 0.6rem;">
                            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 0.75rem;">
                                <input type="text" @bind="newCountryName" placeholder="Country Name..." style="padding:0.55rem; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.08); color:#fff; border-radius:4px; font-family:var(--font-body); font-size:0.85rem;" />
                                <select @bind="newCountryRating" style="padding:0.55rem; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.08); color:#fff; border-radius:4px; font-family:var(--font-body); font-size:0.85rem;" class="text-white">
                                    <option style="color:#000;" value="5">⭐⭐⭐⭐⭐ (5)</option>
                                    <option style="color:#000;" value="4">⭐⭐⭐⭐ (4)</option>
                                    <option style="color:#000;" value="3">⭐⭐⭐ (3)</option>
                                    <option style="color:#000;" value="2">⭐⭐ (2)</option>
                                    <option style="color:#000;" value="1">⭐ (1)</option>
                                </select>
                            </div>
                            <div style="display:flex; gap:0.75rem;">
                                <input type="text" @bind="newCountryOpinion" placeholder="Add opinions, local custom briefs..." style="flex-grow:1; padding:0.55rem; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.08); color:#fff; border-radius:4px; font-family:var(--font-body); font-size:0.85rem; min-width: 0;" />
                                <button type="button" @onclick="AddCountryEntry" style="background:var(--color-primary, #D4AF37); border:none; color:#05120A; font-family:var(--font-display); font-weight:700; font-size:0.75rem; padding:0 1.2rem; border-radius:4px; cursor:pointer; letter-spacing:0.5px; white-space:nowrap;">
                                    COMMIT LOG
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="custom-scrollbar" style="display: flex; flex-direction: column; gap: 1rem; max-height: 260px; overflow-y: auto; padding-right: 0.25rem;">
                        @if (profileModel.VisitedCountries != null && profileModel.VisitedCountries.Any())
                        {
                            @foreach (var log in profileModel.VisitedCountries)
                            {
                                <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); border-radius: 6px; padding: 1rem; position:relative; display: flex; flex-direction: column; gap: 0.25rem; min-width: 0;">
                                    <button type="button" @onclick="() => RemoveCountryEntry(log)" style="position:absolute; top:0.75rem; right:0.75rem; background:none; border:none; color:rgba(255,255,255,0.3); cursor:pointer; font-size:0.85rem;" onmouseover="this.style.color='var(--color-danger)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                    <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap; padding-right: 1.5rem;">
                                        <span style="font-family:var(--font-body); font-weight:600; color:#fff; font-size:0.95rem;">@log.CountryName</span>
                                        <span style="font-size:0.75rem; color:var(--color-primary, #D4AF37);">
                                            @string.Concat(System.Linq.Enumerable.Repeat("★", log.Rating))@string.Concat(System.Linq.Enumerable.Repeat("☆", 5 - log.Rating))
                                        </span>
                                    </div>
                                    <p style="margin:0; font-family:var(--font-body); font-size:0.82rem; color:rgba(255,255,255,0.65); line-height:1.4; padding-right:1.5rem; word-break: break-word;">
                                        @log.Opinion
                                    </p>
                                </div>
                            }
                        }
                        else
                        {
                            <div style="text-align: center; padding: 2.5rem 0; color: rgba(255,255,255,0.35); font-family: var(--font-body); font-size: 0.85rem;">
                                <i class="bi bi-signpost-split" style="font-size: 1.8rem; display: block; margin-bottom: 0.5rem; color: rgba(255,255,255,0.15);"></i>
                                No crossing records registered into this account portfolio yet.
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    }
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.15);
        border-radius: 4px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 4px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: var(--color-primary, #D4AF37);
        }
</style>

@code {
    private string? successMessage;
    private string? errorMessage;
    private string userEmail = string.Empty;
    private bool isEditing = false;

    private string newCountryName = string.Empty;
    private int newCountryRating = 5;
    private string newCountryOpinion = string.Empty;

    private ProfileUpdateDto? profileModel;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var authState = await AuthState;
            var userPrincipal = authState.User;
            if (userPrincipal.Identity?.IsAuthenticated == true)
            {
                var user = await UserManager.GetUserAsync(userPrincipal);
                if (user != null)
                {
                    userEmail = user.Email ?? string.Empty;

                    profileModel = new ProfileUpdateDto
                        {
                            FullName = user.FullName,
                            Nationality = user.Nationality,
                            PreferredLanguage = user.PreferredLanguage,
                            PreferredCurrency = user.PreferredCurrency,
                            Bio = user.Bio,
                            PhoneNumber = user.PhoneNumber,
                            ProfilePictureUrl = user.AvatarUrl
                        };

                    try
                    {
                        if (!string.IsNullOrWhiteSpace(user.SerializedVisitedCountries))
                        {
                            var countries = System.Text.Json.JsonSerializer.Deserialize<List<VisitedCountryLog>>(user.SerializedVisitedCountries);
                            if (countries != null)
                            {
                                profileModel.VisitedCountries = countries;
                            }
                        }
                    }
                    catch
                    {
                        profileModel.VisitedCountries = new List<VisitedCountryLog>();
                    }
                }
            }
        }
    }

    private void ToggleEditMode()
    {
        isEditing = !isEditing;
        successMessage = null;
        errorMessage = null;
    }

    private async Task AddCountryEntry()
    {
        if (string.IsNullOrWhiteSpace(newCountryName) || profileModel == null) return;

        profileModel.VisitedCountries.Insert(0, new VisitedCountryLog
            {
                CountryName = newCountryName,
                Rating = newCountryRating,
                Opinion = string.IsNullOrWhiteSpace(newCountryOpinion) ? "No detailed custom narrative committed." : newCountryOpinion
            });

        newCountryName = string.Empty;
        newCountryRating = 5;
        newCountryOpinion = string.Empty;

        await SaveLedgerToDatabase();
    }

    private async Task RemoveCountryEntry(VisitedCountryLog target)
    {
        if (profileModel == null) return;
        profileModel.VisitedCountries.Remove(target);
        await SaveLedgerToDatabase();
    }

    private async Task SaveLedgerToDatabase()
    {
        if (AuthState == null || profileModel == null) return;
        var authState = await AuthState;
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null)
        {
            user.SerializedVisitedCountries = System.Text.Json.JsonSerializer.Serialize(profileModel.VisitedCountries);
            await UserManager.UpdateAsync(user);
        }
    }

    private async Task HandleUpdate()
    {
        successMessage = null;
        errorMessage = null;

        if (AuthState == null || profileModel == null) return;

        var authState = await AuthState;
        var user = await UserManager.GetUserAsync(authState.User);
        if (user == null) return;

        user.FullName = profileModel.FullName;
        user.Nationality = profileModel.Nationality;
        user.PreferredLanguage = profileModel.PreferredLanguage;
        user.PreferredCurrency = profileModel.PreferredCurrency;
        user.Bio = profileModel.Bio;
        user.PhoneNumber = profileModel.PhoneNumber;
        user.AvatarUrl = profileModel.ProfilePictureUrl;
        user.SerializedVisitedCountries = System.Text.Json.JsonSerializer.Serialize(profileModel.VisitedCountries);

        var result = await UserManager.UpdateAsync(user);
        if (result.Succeeded)
        {
            successMessage = "Explorer profile configuration details saved directly to system vaults.";
            isEditing = false;
        }
        else
        {
            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
        }
    }
}