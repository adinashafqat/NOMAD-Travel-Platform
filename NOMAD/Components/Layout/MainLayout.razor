@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Identity
@using NOMAD.Services
@implements IDisposable
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavigationManager
@inject NotificationService Notifier

<div class="nomad-app-shell @(isSidebarOpen ? "sidebar-open" : "") @(IsAuthPage ? "auth-context-layout" : "")">
    <NOMAD.Components.Shared.NotificationToast />

    @if (!IsAuthPage)
    {
        <aside class="nomad-sidebar glass-panel">
            <div class="sidebar-brand">
                <button class="mobile-toggle d-md-none" @onclick="ToggleSidebar" type="button">
                    <i class="bi bi-list"></i>
                </button>
                <h2 class="text-gradient">N</h2>
                <span class="brand-text">NOMAD</span>
            </div>

            <nav class="sidebar-nav">
                <NavLink class="nav-item-nomad" href="/dashboard" Match="NavLinkMatch.All">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Dashboard</span>
                </NavLink>
                <NavLink class="nav-item-nomad" href="/map">
                    <i class="bi bi-map-fill"></i>
                    <span>Live Radar</span>
                </NavLink>
                <NavLink class="nav-item-nomad" href="/weather">
                    <i class="bi bi-cloud-lightning-rain-fill"></i>
                    <span>Weather Intel</span>
                </NavLink>
                <NavLink class="nav-item-nomad" href="/finance">
                    <i class="bi bi-graph-up-arrow"></i>
                    <span>Finances</span>
                </NavLink>
                <NavLink class="nav-item-nomad" href="/translate">
                    <i class="bi bi-translate"></i>
                    <span>Translator</span>
                </NavLink>
                <NavLink class="nav-item-nomad" href="/culture">
                    <i class="bi bi-globe-americas"></i>
                    <span>Intel Guide</span>
                </NavLink>
                <NavLink class="nav-item-nomad" href="/offline">
                    <i class="bi bi-hdd-network-fill"></i>
                    <span>Offline Vault</span>
                </NavLink>
                <NavLink class="nav-item-nomad" href="/profile">
                    <i class="bi bi-person-circle"></i>
                    <span>Profile</span>
                </NavLink>
            </nav>

            <div style="padding: 1rem;">
                <NavLink class="nomad-btn" href="/emergency" style="display: flex !important; width: 100% !important; justify-content: center !important; background: rgba(211,47,47,0.15) !important; border-color: var(--color-danger) !important; color: #F4EADA !important; box-shadow: 0 0 15px rgba(211,47,47,0.25) !important;">
                    <i class="bi bi-exclamation-triangle-fill" style="color: var(--color-danger) !important; margin-right: 8px !important;"></i> SOS OVERRIDE
                </NavLink>
            </div>

            <div class="sidebar-footer">
                <a href="/logout" class="nav-item-nomad logout-link">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>
    }

    <div class="nomad-content-area">
        @if (!IsAuthPage)
        {
            <header class="nomad-topbar glass-panel">
                <div class="topbar-left">
                    <button class="mobile-nav-toggle d-md-none" @onclick="ToggleSidebar" type="button">
                        <i class="bi bi-list"></i>
                    </button>
                    <h4 class="topbar-title">COMMAND CENTER</h4>
                </div>
                <div class="topbar-right">
                    <div class="topbar-user">
                        <i class="bi bi-circle-fill status-dot"></i>
                        <span class="user-name">@currentUserName</span>
                    </div>
                </div>
            </header>
        }

        <main class="nomad-main">
            @Body
        </main>
    </div>
</div>

<style>
    html, body {
        margin: 0 !important;
        padding: 0 !important;
        height: 100vh !important;
        overflow: hidden !important;
    }

    .nomad-app-shell {
        display: grid !important;
        grid-template-columns: 260px 1fr !important;
        width: 100vw !important;
        max-width: 100vw !important;
        height: 100vh !important;
        max-height: 100vh !important;
        overflow: hidden !important;
        position: relative !important;
    }

        .nomad-app-shell.auth-context-layout {
            grid-template-columns: 1fr !important;
        }

    .nomad-sidebar {
        width: 260px !important;
        height: 100% !important;
        display: flex !important;
        flex-direction: column !important;
        z-index: 1000 !important;
        flex-shrink: 0 !important;
    }

    .nomad-content-area {
        display: flex !important;
        flex-direction: column !important;
        height: 100% !important;
        max-height: 100vh !important;
        overflow-y: auto !important;
        overflow-x: hidden !important;
        min-width: 0 !important;
        width: 100% !important;
    }

    .nomad-main {
        flex-grow: 1 !important;
        padding: 1.5rem !important;
        width: 100% !important;
        display: block !important;
    }

    @@media (max-width: 767.98px) {
        .nomad-app-shell {
            grid-template-columns: 1fr !important;
        }

        .nomad-sidebar {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            height: 100vh !important;
            transform: translateX(-100%) !important;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
            box-shadow: 20px 0 40px rgba(0, 0, 0, 0.5) !important;
        }

        .nomad-app-shell.sidebar-open .nomad-sidebar {
            transform: translateX(0) !important;
        }

        .nomad-app-shell.sidebar-open .nomad-content-area::before {
            content: "" !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            background: rgba(0, 0, 0, 0.5) !important;
            backdrop-filter: blur(4px) !important;
            z-index: 999 !important;
        }
    }

    @@media (min-width: 768px) {
        .d-md-none {
            display: none !important;
        }

        .nomad-sidebar {
            transform: translateX(0) !important;
        }
    }
</style>

@code {
    private string currentUserName = "Explorer";
    private bool isSidebarOpen = false;

    private bool IsAuthPage =>
        NavigationManager.Uri.Contains("/login", StringComparison.OrdinalIgnoreCase) ||
        NavigationManager.Uri.Contains("/register", StringComparison.OrdinalIgnoreCase) ||
        NavigationManager.Uri.Contains("/logout", StringComparison.OrdinalIgnoreCase);

    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;

        Notifier.StartSimulation();

        Notifier.OnNotify += OnNotificationStateChanged;

        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext?.User?.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(httpContext.User);
            if (user != null)
            {
                currentUserName = user.FullName;
            }
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private void OnNotificationStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        Notifier.OnNotify -= OnNotificationStateChanged;
    }
}